# Dependencies (installed fresh inside the image)
node_modules
.pnpm-store

# Build output / caches (regenerated by `pnpm build`)
.next
.turbo
.vercel
dist
build
out
*.tsbuildinfo

# Version control
.git
.gitignore
.github

# Docker itself
Dockerfile*
docker-compose*.yml
.dockerignore

# Editors / OS cruft
.vscode
.idea
.DS_Store

# Env files (secrets should never be baked into the image; pass them at
# `docker run` time instead). .env.example is intentionally NOT ignored.
.env
.env.*
!.env.example

# Docs
README.md
Readme.md
CHANGELOG.md

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Tests / coverage (not needed at runtime; still run in CI before the image
# is built)
coverage
**/__tests__
**/*.test.ts
**/*.test.tsx
